# 依赖
node_modules/
**/node_modules/

# 构建产物
code/dist/
desktop/dist/
desktop/dist-installer/
results/portable/

# 日志
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# 编辑器
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# 环境变量 / 敏感数据
.env
.env.*
!.env.example

# 用户本地数据备份(不应提交)
data/*.json
!data/.gitkeep

# 调研原始资料(体积大、非必要)
title/raw/*.js
title/raw/*.html
title/cn_strings.txt
title/_raw_home.html

# TS 构建缓存
*.tsbuildinfo
code/.vite/

# Python 调研脚本产物
**/__pycache__/
*.pyc

# 临时
*.tmp
*.bak
